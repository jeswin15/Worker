# Environment Variables Example for Startup Sourcing Agent

# LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# Data Source APIs
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=HoloceneEvaluator/1.0
GITHUB_TOKEN=your_github_token
PRODUCT_HUNT_API_KEY=your_ph_api_key

# Google Sheets Integration
GSHEET_CREDENTIALS_JSON=credentials.json
GSHEET_NAME=Holocene Startup Sourcing

# Database Configuration
# Options: local_json, mongodb
DATABASE_TYPE=mongodb
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/holocene_sourcing?retryWrites=true&w=majority
MONGO_DB_NAME=holocene_sourcing

# Email Outreach
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
OUTREACH_EMAIL_SENDER=Investment Interest - Holocene
